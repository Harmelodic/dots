#!/bin/bash

# Clone all repos from a GitLab group. Syntax: glgc group[/subgroup]

source "$DOTS/config-files/vars"

groupName=${1//\//\%2F} # If subgroup is given, replace / with %2F.

curl -s --header "Private-Token: $GLGC_TOKEN" "https://gitlab.com/api/v4/groups/$groupName/projects" |
	jq ".[].http_url_to_repo" |
	xargs -I {} git clone {}
