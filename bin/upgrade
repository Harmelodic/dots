#!/bin/bash

# Runs the update/upgrade commands on package managers & tools, then outputs the current/new versions

set -x

# OS-specific
if [[ "$(uname)" =~ "Darwin" ]]; then
	if type brew 1> /dev/null 2> /dev/null; then
		brew update
		brew -v
		brew upgrade
		brew list
		brew upgrade --cask
		brew list --cask
	fi
elif [[ "$(uname -a)" =~ "MANJARO" ]]; then
	sudo pacman --sync --refresh --sysupgrade # Upgrade synchronized packages (long form of `pacman -Syu`)

	packages_to_prune=$(sudo pacman --query --deps --unrequired --quiet)
	sudo pacman --remove --recursive --nosave "$packages_to_prune" || echo "Nothing to prune"

	# Could just do pamac upgrade, but I would rather use the native Arch Linux package manager than Manjaro's.
	# Using pamac simply to ensure AUR packages are upgraded too.
	pamac upgrade --aur
	pamac remove --orphans

	# Firmware Update Manager
	if type fwupdmgr 1> /dev/null 2> /dev/null; then
		fwupdmgr upgrade
	fi
elif [[ "$(uname -a)" =~ "Ubuntu" ]]; then
	sudo apt update
	sudo apt upgrade
	sudo apt autoremove

	snap refresh

	# Firmware Update Manager
	if type fwupdmgr 1> /dev/null 2> /dev/null; then
		fwupdmgr upgrade
	fi
else
	echo -e "\nNo OS Specific updates to install for $(uname)"
fi

# OS-agnostic

if type rustup 1> /dev/null 2> /dev/null; then
	rustup update
	rustup -V
	rustc -V
fi

if type mise 1> /dev/null 2> /dev/null; then
	mise upgrade update
	mise self-update
	mise version
	mkdir -p "$HOME/.config/mise"
	cp "$HOME/dots/config-files/mise.config.toml" "$HOME/.config/mise/config.toml"
	mise install
	mise upgrade --dry-run
fi

if type krew 1> /dev/null 2> /dev/null; then
	krew upgrade
fi

dots upgrade
