#!/bin/bash

# Outputs the current/new versions & packages installed on current machine

set -x

# OS Specific
if [[ "$(uname)" =~ "Darwin" ]]; then
	brew --version
	brew list
	brew list --cask
elif [[ "$(uname -a)" =~ "MANJARO" ]]; then
	pacman --version

	if type fwupdmgr 1> /dev/null 2> /dev/null; then
		fwupdmgr --version
	fi
elif [[ "$(uname -a)" =~ "Ubuntu" ]]; then
	apt --version
	apt list 2> /dev/null | wc -l
	snap --version

	if type flatpak 1> /dev/null 2> /dev/null; then
		flatpak --version
		flatpak list
	fi

	if type fwupdmgr 1> /dev/null 2> /dev/null; then
		fwupdmgr --version
	fi
else
	echo -e "\nNo OS Specific updates to install for $(uname)"
fi

gcloud version | head -1

if type rustc 1> /dev/null 2> /dev/null; then
	rustc --version
fi

if type mise 1> /dev/null 2> /dev/null; then
	mise version
	mise list
fi

if type krew 1> /dev/null 2> /dev/null; then
	krew list
fi

dots version
