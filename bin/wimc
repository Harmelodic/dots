#!/bin/bash

# wimc = What Is My Config? - Outputs config for common development tools.

set -x

if [[ "$(uname)" =~ "Darwin" ]]; then
	mise list
else
	echo -e "\nNo OS Specific updates to install for $(uname)"
fi

echo "External IP"
dig +short myip.opendns.com @resolver1.opendns.com

echo "git"
git config --list | grep -v alias

echo "gcloud"
gcloud config list

echo "aws"
aws configure list

echo "kubectl"
kubectl config current-context
