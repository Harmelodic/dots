#!/bin/bash

# Completely rewrite the history of your branch - Uses git-filter-branch - USE WITH CAUTION

username=$1
email=$2

if [ -z "$username" ] && [ -z "$email" ]; then
	echo "Usage:"
	echo "$ grw Username email@domain.com"
	exit 1
fi

set -x

git filter-branch -f --env-filter "GIT_AUTHOR_NAME='$username'; GIT_AUTHOR_EMAIL='$email'; GIT_COMMITTER_NAME='$username'; GIT_COMMITTER_EMAIL='$email';" HEAD
