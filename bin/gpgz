#!/bin/bash

# gpgz = Portmanteau of gpg and easy - helper function for git-related bits of gpg

if [ -z "$1" ]; then
	echo "$ gpgz new"
	echo "to create a new gpg key"
	echo "or"
	echo "$ gpgz <email>"
	echo "to get the SEC GPG Key ID and the public key for the email entered"
	exit 1
fi

if [[ $1 == "new" ]]; then
	set -x
	gpg --full-gen-key
elif [[ $1 == *"@"* ]]; then
	set -x
	SEC_CODE=$(gpg --list-secret-keys --keyid-format LONG "$1" | grep sec | awk '{print $2}' | cut -c9-)
	echo "sec $SEC_CODE"
	gpg --armor --export "$SEC_CODE"
fi
