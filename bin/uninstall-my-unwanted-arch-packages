#!/bin/bash

# Install my arch packages as defined in my Manjaro config.

set -x

yq '.uninstall.arch-core-or-extra.[]' < "$DOTS/config-files/manjaro-packages.yaml" |
	sudo pacman --query --quiet - 2> /dev/null |
	cat |
	sudo pacman --remove --recursive - || echo -e "\nScript: Nothing to remove (empty stdin), or removal failed (see error above)".
