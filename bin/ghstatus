#!/bin/bash

# ghstatus - GitHub Status - Get Check Suite statuses of all repos for a user, on the main branch

user=$1

if [ -z "$user" ]; then
	echo "Please provide the user:"
	echo "$ ghstatus <user>"
	exit 1
fi

repos=$(gh api "/users/$user/repos" | jq -r '.[].name')

for repo in $repos; do
	echo "===> $repo"
	gh api "/repos/$user/$repo/commits/main/check-suites" |
		jq '.check_suites.[]' |
		jq '(.status) + ":" + (.app.slug) + ":" + (.conclusion)'
done
